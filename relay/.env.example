# Porta em que o relay escuta (lembre de abrir no firewall da Oracle)
PORT=8787

# Segredo compartilhado exigido no header Authorization do webhook /notify
# Gere algo forte, ex.: openssl rand -hex 32
RELAY_SECRET=troque-por-um-segredo-forte

# Caminho do service account JSON do Firebase (NÃO versionar)
GOOGLE_APPLICATION_CREDENTIALS=/opt/gertec-relay/certs/firebase-sa.json

# Onde guardar os tokens dos dispositivos registrados
TOKENS_PATH=/opt/gertec-relay/data/tokens.json

# ── Self-updater (webhook do GitHub que reinicia o serviço a cada push) ─────────
WEBHOOK_UPDATER_PORT=9001
# Mesmo "Secret" configurado no webhook do repositório no GitHub (HMAC SHA256)
WEBHOOK_UPDATER_SECRET=troque-por-outro-segredo-forte
GITHUB_BRANCH=main
RELAY_SERVICE_NAME=gertec-relay
